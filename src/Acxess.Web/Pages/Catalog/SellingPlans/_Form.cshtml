@model SellingPlanInputModel
<form 
    id="sellingPlanForm" 
    method="post" 
    hx-post="?handler=Save" 
    hx-target="this" 
    hx-swap="outerHTML"
    hx-indicator="#btnSave"
    class="flex flex-col gap-3">
@* 
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4">
            <strong class="font-bold">Hay errores en el modelo:</strong>
            <ul class="list-disc pl-5 text-sm">
                @foreach (var key in ViewData.ModelState.Keys)
                {
                    foreach (var error in ViewData.ModelState[key]!.Errors)
                    {
                        <li>Key: <b>@key</b> - Error: @error.ErrorMessage</li>
                    }
                }
            </ul>
        </div>
    } *@


    <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>
    <input type="hidden" name="Input.IdSellingPlan" :value="form.idSellingPlan" />

    <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Nombre Comercial</label>
        <input 
            type="text" 
            class="w-full p-2.5 bg-white dark:bg-slate-900 border border-gray-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none shadow-sm text-gray-900 dark:text-white transition-colors" 
            placeholder="Ej. Mensualidad Estudiante"
            name="Input.Name"
            id="Input_Name"
            x-model="form.name">
        @Html.ValidationMessage("Input.Name", new { @class = "text-xs text-red-500 font-bold mt-1 block" })

    </div>
    
    <div class="">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Cantidad de Miembros</label>
        <input 
            type="number" 
            class="w-full p-2.5 bg-white dark:bg-slate-900 border border-gray-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none shadow-sm text-gray-900 dark:text-white transition-colors" 
            placeholder="Ej. 3"
            name="Input.TotalMembers"
            id="Input_TotalMembers"
            x-model="form.totalMembers">
        @Html.ValidationMessage("Input.TotalMembers", new { @class = "text-xs text-red-500 font-bold mt-1 block" })
    </div>

    <div class="grid grid-cols-2 gap-4 ">
        <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Precio</label>
            <div class="relative group">
                <span class="absolute left-3 top-2.5 text-gray-400 group-focus-within:text-blue-500 transition-colors">$</span>
                <input 
                    type="number" 
                    name="Input.Price"
                    id="Input_Price"
                    x-model.number="form.price" 
                    class="w-full p-2.5 pl-7 bg-white dark:bg-slate-900 border border-gray-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none shadow-sm font-mono font-bold text-gray-700 dark:text-white transition-colors">
                
                @Html.ValidationMessage("Input.Price", new { @class = "text-xs text-red-500 font-bold mt-1 block" })
            </div>
        </div>
        
        <div class="flex flex-col justify-end pb-2">
            <label class="flex items-center cursor-pointer group">
                <div class="relative">
                    <input type="checkbox" x-model="form.isActive" class="sr-only">
                    <div :class="form.isActive ? 'bg-green-500' : 'bg-gray-300 dark:bg-slate-600'" class="w-10 h-6 rounded-full shadow-inner transition-colors"></div>
                    <div :class="form.isActive ? 'translate-x-4' : 'translate-x-0'" class="absolute left-1 top-1 bg-white w-4 h-4 rounded-full shadow transition-transform transform"></div>
                </div>
                <span class="ml-3 text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:text-blue-500 transition-colors" x-text="form.isActive ? 'Disponible' : 'Archivado'"></span>
            </label>
        </div>

        
    </div>

    <div class=" bg-white dark:bg-slate-800 p-4 rounded-lg border border-gray-200 dark:border-slate-700 shadow-sm">
        <label class="block text-xs font-bold text-gray-400 dark:text-gray-500 uppercase mb-3 tracking-wide">Vigencia del servicio</label>
        <div class="flex gap-4">
            <div class="w-1/3">
                <label class="text-xs text-gray-500 dark:text-gray-400 block mb-1">Valor</label>
                <input 
                    type="number" 
                    name="Input.DurationInValue"
                    id="Input_DurationInValue"
                    x-model="form.durationInValue" 
                    class="w-full p-2 border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-white rounded focus:ring-blue-500 outline-none transition-colors">
                @Html.ValidationMessage("Input.DurationInValue", new { @class = "text-xs text-red-500 font-bold mt-1 block" })
            </div>
            <div class="flex-1">
                <label class="text-xs text-gray-500 dark:text-gray-400 block mb-1">Unidad</label>
                <select 
                        name="Input.DurationUnit"
                        id="Input_durationUnit"<<
                        x-model="form.durationUnit" 
                        class="w-full p-2 border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-white rounded focus:ring-blue-500 outline-none transition-colors">
                    <option value="1">Días</option>
                    <option value="2">Meses</option>
                    <option value="3">Años</option>
                </select>
            </div>
        </div>
        <p class="mt-3 text-xs text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20 p-2 rounded border border-blue-100 dark:border-blue-900/30">
            <span class="font-bold">Info:</span> El sistema sumará <span x-text="form.durationValue"></span> <span x-text="mapDayUnit(form.durationUnit)"></span> a la fecha de compra.
        </p>
    </div>


    
    <div class="flex flex-col justify-between items-start mb-1">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Cantidad de Miembros</label>
        @Html.ValidationMessage("Input.AccessTiersIds", new { @class = "text-xs text-red-500 dark:text-red-400 font-bold block" })
    </div>

    <div class="grid grid-cols-2 gap-2">
        <template x-for="accessTier in accessTiers" :key="accessTier.id">
            <div @@click="toggleAccessTiers(accessTier.id)" 
                class="cursor-pointer border p-2 rounded text-xs flex items-center gap-2 transition-colors duration-200 select-none"
                :class="form.accessTiersIds.includes(accessTier.id) 
                    ? 'bg-blue-50 border-blue-500 text-blue-700 dark:bg-blue-900/30 dark:border-blue-500 dark:text-blue-300' 
                    : 'bg-white border-gray-200 text-gray-600 dark:bg-slate-900 dark:border-slate-700 dark:text-gray-300 hover:border-gray-300 dark:hover:border-slate-500'">
                
                <div 
                    class="w-4 h-4 border rounded flex items-center justify-center transition-colors"
                    :class="form.accessTiersIds.includes(accessTier.id) 
                        ? 'bg-blue-500 border-blue-500 dark:bg-blue-600 dark:border-blue-600' 
                        : 'border-gray-300 dark:border-slate-500'">
                    
                    <svg x-show="form.accessTiersIds.includes(accessTier.id)" class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                </div>
                
                <span x-text="accessTier.name"></span>
            </div>
        </template>
    </div>

    <template x-for="(id, index) in form.accessTiersIds" :key="id">
        <input type="hidden" name="Input.AccessTiersIds" :value="id" />
    </template>


    
</form>