@using Acxess.Catalog.Application.Features.AccessTiers.Queries.GetAccessTiers
@using System.Text.Json
@model SellingPlanInputModel
@{
    var successMsg = ViewData["SuccessMessage"] as string;
    var errorMsg = ViewData["ErrorMessage"] as string;
    var warningMsg = ViewData["WarningMessage"] as string;

    var availableTiers = ViewData["AvailableTiers"] as List<AccessTierDto> ?? new List<AccessTierDto>();

    var initialDurationVal = Model.DurationInValue > 0 ? Model.DurationInValue : 1;
    var initialDurationUnit = Model.DurationUnit > 0 ? Model.DurationUnit : 1;


    var selectedIdsJson = JsonSerializer.Serialize(Model.AccessTiersIds);
    var tiersMapJson = JsonSerializer.Serialize(availableTiers.ToDictionary(x => x.IdAccessTier, x => x.Name));
}
<div class="h-full flex flex-col bg-gray-50 dark:bg-[#0f1523]"
    x-data='{ 
        name: "@(Model.Name?.Replace("\"", "\\\"") ?? "")",
        price: "@(Model.Price)",
        isActive: @Model.IsActive.ToString().ToLower(),
        totalMembers: @(Model.TotalMembers > 0 ? Model.TotalMembers : 1),
        durationVal: @initialDurationVal,
        durationUnit: @initialDurationUnit,
        selectedTiers: @Html.Raw(selectedIdsJson),
        tiersMap: @Html.Raw(tiersMapJson),
        units: { 
            1: "Días", 
            2: "Meses", 
            3: "Años" 
        },
        getTiersNames() {
            if (this.selectedTiers.length > 0) {
                return this.selectedTiers
                    .map(id => this.tiersMap[id])
                    .filter(n => n) 
                    .join(", ");
            }
            return "";
        }
     }'>


    <div class="flex-1 p-8 grid grid-cols-1  lg:grid-cols-2 overflow-y-auto gap-12 custom-scrollbar content-start">
        <div class="space-y-6">
            <div class="mb-6">
                <h2 class="text-lg font-bold text-gray-800 dark:text-white flex items-center gap-2">
                    <span>@(Model.IdSellingPlan == 0 ? "Crear Nuevo Plan" : "Editar Plan")</span>
                </h2>
                <p class="text-sm text-gray-500 dark:text-gray-400">Define las reglas de negocio para esta configuración.</p>
                @if (!string.IsNullOrEmpty(successMsg))
                {
                    <div x-data="{ show: true }"
                        x-show="show"
                        x-transition:enter="transition ease-out duration-300"
                        x-transition:enter-start="opacity-0 translate-y-2 scale-95"
                        x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                        x-transition:leave="transition ease-in duration-200"
                        x-transition:leave-start="opacity-100 scale-100"
                        x-transition:leave-end="opacity-0 scale-95"
                        x-init="setTimeout(() => show = false, 5000)"
                        class="mt-2 flex items-start p-3 mb-4 text-emerald-800 border border-emerald-200 rounded-lg bg-emerald-50 dark:bg-emerald-900/20 dark:text-emerald-300 dark:border-emerald-800 shadow-sm "
                        role="alert">
                        
                        <svg class="flex-shrink-0 w-5 h-5 mt-0.5 me-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5Zm3.707 8.207-4 4a1 1 0 0 1-1.414 0l-2-2a1 1 0 0 1 1.414-1.414L9 10.586l3.293-3.293a1 1 0 0 1 1.414 1.414Z"/>
                        </svg>
                        
                        <div class="flex-1 text-sm font-medium">
                            <span class="font-bold block mb-1">¡Operación exitosa!</span>
                            @successMsg
                        </div>

                        <button @@click="show = false" type="button" class="ms-auto -mx-1.5 -my-1.5 bg-emerald-50 text-emerald-500 rounded-lg focus:ring-2 focus:ring-emerald-400 p-1.5 hover:bg-emerald-200 inline-flex items-center justify-center h-8 w-8 dark:bg-transparent dark:text-emerald-400 dark:hover:bg-emerald-800 transition-colors">
                            <span class="sr-only">Cerrar</span>
                            <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                            </svg>
                        </button>
                    </div>
                }
            </div>

            <form 
                id="sellingPlanForm"
                method="post" 
                hx-post="@Url.Page("Index", "Save")" 
                hx-target="#form-container" 
                class="flex flex-col gap-3"
            >

                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>
                <input type="hidden" asp-for="IdSellingPlan" />

                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Nombre Comercial</label>
                    <input 
                        type="text" 
                        class="w-full p-2.5 bg-white dark:bg-slate-900 border border-gray-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none shadow-sm text-gray-900 dark:text-white transition-colors" 
                        asp-for="Name"
                        placeholder="Ej. Mensualidad Estudiante"
                        name="Input.Name"
                        x-model="name"
                        id="Input_Name">
                    <span asp-validation-for="Name" class="text-xs text-red-500 font-bold mt-1 block"></span>
                </div>

                <div >
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Cantidad de Miembros</label>
                    <input 
                        type="number" 
                        class="w-full p-2.5 bg-white dark:bg-slate-900 border border-gray-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none shadow-sm text-gray-900 dark:text-white transition-colors" 
                        placeholder="Ej. 3"
                        name="Input.TotalMembers"
                        id="Input_TotalMembers"
                        asp-for="TotalMembers"
                        x-model="totalMembers">
                    <span asp-validation-for="TotalMembers" class="text-xs text-red-500 font-bold mt-1 block"></span>
                </div>


                <div class="grid grid-cols-2 gap-4 ">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Precio</label>
                        <div class="relative group">
                            <span class="absolute left-3 top-2.5 text-gray-400 group-focus-within:text-blue-500 transition-colors">$</span>
                            <input 
                                type="number" 
                                name="Input.Price"
                                id="Input_Price"
                                asp-for="Price"
                                x-model="price"
                                class="w-full p-2.5 pl-7 bg-white dark:bg-slate-900 border border-gray-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none shadow-sm font-mono font-bold text-gray-700 dark:text-white transition-colors">
                            
                            <span asp-validation-for="Price" class="text-xs text-red-500 font-bold mt-1 block"></span>
                        </div>
                    </div>
                    
                    <div class="flex flex-col justify-end pb-2">
                        <label class="flex items-center cursor-pointer group">
                            <div class="relative">
                                <input type="checkbox" asp-for="IsActive" x-model="isActive"  class="sr-only">
                                <div :class="isActive ? 'bg-green-500' : 'bg-gray-300 dark:bg-slate-600'" class="w-10 h-6 rounded-full shadow-inner transition-colors"></div>
                                <div :class="isActive ? 'translate-x-4' : 'translate-x-0'" class="absolute left-1 top-1 bg-white w-4 h-4 rounded-full shadow transition-transform transform"></div>
                            </div>
                            <span class="ml-3 text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:text-blue-500 transition-colors" x-text="isActive ? 'Disponible' : 'Archivado'"></span>
                        </label>
                    </div>

                    
                </div>

                <div class=" bg-white dark:bg-slate-800 p-4 rounded-lg border border-gray-200 dark:border-slate-700 shadow-sm">
                    <label class="block text-xs font-bold text-gray-400 dark:text-gray-500 uppercase mb-3 tracking-wide">Vigencia del servicio</label>
                    <div class="flex gap-4">
                        <div class="w-1/3">
                            <label class="text-xs text-gray-500 dark:text-gray-400 block mb-1">Valor</label>
                            <input 
                                type="number" 
                                name="Input.DurationInValue"
                                asp-for="DurationInValue"
                                id="Input_DurationInValue"
                                x-model="durationVal"
                                class="w-full p-2 border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-white rounded focus:ring-blue-500 outline-none transition-colors">
                            <span asp-validation-for="DurationInValue" class="text-xs text-red-500 font-bold mt-1 block"></span>
                        </div>
                        <div class="flex-1">
                            <label class="text-xs text-gray-500 dark:text-gray-400 block mb-1">Unidad</label>
                            <select 
                                    name="Input.DurationUnit"
                                    id="Input_durationUnit"
                                    asp-for="DurationUnit"
                                    x-model.number="durationUnit"
                                    class="w-full p-2 border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-white rounded focus:ring-blue-500 outline-none transition-colors">
                                <option value="1">Días</option>
                                <option value="2">Meses</option>
                                <option value="3">Años</option>
                            </select>
                        </div>
                    </div>
                    <p class="mt-3 text-xs text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20 p-2 rounded border border-blue-100 dark:border-blue-900/30">
                        <span class="font-bold">Info:</span> El sistema sumará 
                        <span x-text="durationVal"></span> 
                        <span x-text="units[durationUnit] || 'Unidad'"></span> 
                        a la fecha de compra.
                    </p>
                </div>

                <div class="flex flex-col justify-between items-start mb-1">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Niveles de acceso</label>
                    <span asp-validation-for="AccessTiersIds" class="text-xs text-red-500 dark:text-red-400 font-bold block"></span>
                </div>

                <div class="grid grid-cols-2 gap-2">
                    @foreach (var tier in availableTiers)
                    {
                        bool isSelected = Model.AccessTiersIds.Contains(tier.IdAccessTier);
                        
                        <label x-data="{ checked: @isSelected.ToString().ToLower() }" 
                            class="cursor-pointer border p-2 rounded text-xs flex items-center gap-2 transition-colors duration-200 select-none"
                            :class="checked
                                    ? 'bg-blue-50 border-blue-500 text-blue-700 dark:bg-blue-900/30 dark:border-blue-500 dark:text-blue-300' 
                                    : 'bg-white border-gray-200 text-gray-600 dark:bg-slate-900 dark:border-slate-700 dark:text-gray-300 hover:border-gray-300 dark:hover:border-slate-500'">
                            
     

                                <input type="checkbox" 
                                    name="Input.AccessTiersIds" 
                                    value="@tier.IdAccessTier" 
                                    class="hidden" 
                                    x-model.number="selectedTiers" />

                            <div class="w-4 h-4 border rounded flex items-center justify-center transition-colors"
                                :class="selectedTiers.includes(@tier.IdAccessTier)
                                    ? 'bg-blue-500 border-blue-500 dark:bg-blue-600 dark:border-blue-600' 
                                    : 'border-gray-300 dark:border-slate-500'">
                                
                                <svg x-show="selectedTiers.includes(@tier.IdAccessTier)" 
                                    x-transition.opacity 
                                    class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                </svg>
                            </div>
                            
                            <span>@tier.Name</span>
                        </label>
                    }

                </div>


            </form>

        </div>

        <partial name="_PreviewPlan" />
    </div>

    <div class="bg-white dark:bg-slate-800 border-t border-gray-200 dark:border-slate-700 p-4 flex justify-between items-center shrink-0 z-20 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)]">
            
        <button 
            type="button"
            @@click="selectedId = null"
            hx-get="@Url.Page("Index", "Form")" 
            hx-target="#form-container"
            class="px-4 py-2 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-slate-700 rounded-lg text-sm transition-colors">
            Cancelar <span class="bg-gray-200 dark:bg-slate-600 text-gray-500 dark:text-gray-300 px-1 py-0.5 rounded text-[10px] ml-1 border border-gray-300 dark:border-slate-500">Esc</span>
        </button>
            
        <button 
            id="btnSave"
            class="px-6 py-2 bg-slate-900 hover:bg-black dark:bg-blue-600 dark:hover:bg-blue-500 text-white rounded-lg shadow-lg text-sm font-bold flex items-center gap-2 transform active:scale-95 transition-all disabled:opacity-70 disabled:cursor-not-allowed"
            type="submit"
            form="sellingPlanForm"
            :disabled="isLoading">
            
            <span x-show="!isLoading">GUARDAR CAMBIOS</span>
            
            <span x-show="isLoading" class="flex items-center gap-2">
                GUARDANDO...
                <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
            </span>
        </button>
    </div>
</div>
