@model string

<header class="bg-white dark:bg-slate-800 p-2 flex items-center 
                gap-4 shadow-sm border-b border-gray-200 
                dark:border-slate-700 shrink-0 z-20">
        
    <a href="/Catalog/Index" class="group flex items-center justify-center w-8 h-8 rounded-full hover:bg-gray-100 dark:hover:bg-slate-700 text-gray-500 dark:text-gray-400 transition-colors" title="Volver al Menú">
        <svg class="w-5 h-5 text-gray-600 dark:text-gray-300 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
    </a>

    <div class="flex flex-col gap-1">
        <h1 class="text-lg font-bold tracking-tight text-slate-800 dark:text-white leading-tight">
            @Model
        </h1>
        <span class="text-xs text-gray-400 dark:text-gray-500 font-medium">Configuración de Catálogo</span>
    </div>
</header>