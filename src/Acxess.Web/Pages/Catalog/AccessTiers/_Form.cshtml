@model AccessTierInput
<form 
    id="sellingPlanForm"
    method="post" 
    hx-post="?handler=Save" 
    hx-target="this" 
    hx-swap="outerHTML"
    class="flex flex-col gap-3">

    <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>
    <input type="hidden" name="Input.IdAccessTier" :value="form.idAccessTier" />
    <input type="hidden" name="Input.IsActive" :value="form.isActive.toString()" />

    <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Nombre del Nivel de Acceso</label>
        <input 
            type="text" 
            class="w-full p-2.5 bg-white dark:bg-slate-900 border border-gray-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none shadow-sm text-gray-900 dark:text-white transition-colors" 
            placeholder="Ej. Área en especifica"
            name="Input.Name"
            id="Input_Name"
            x-model="form.name">
        @Html.ValidationMessage("Input.Name", new { @class = "text-xs text-red-500 font-bold mt-1 block" })
    </div>

    <div class="flex flex-col justify-end pb-2">
        <label class="flex items-center cursor-pointer group">
            <div class="relative">
                <input type="checkbox" x-model="form.isActive" asp-for="IsActive" class="sr-only">
                <div :class="form.isActive ? 'bg-green-500' : 'bg-gray-300 dark:bg-slate-600'" class="w-10 h-6 rounded-full shadow-inner transition-colors"></div>
                <div :class="form.isActive ? 'translate-x-4' : 'translate-x-0'" class="absolute left-1 top-1 bg-white w-4 h-4 rounded-full shadow transition-transform transform"></div>
            </div>
            <span class="ml-3 text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:text-blue-500 transition-colors" x-text="form.isActive ? 'Disponible' : 'Archivado'"></span>
        </label>
    </div>

    <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Descripción(opcional)</label>
        <textarea 
          class="w-full p-2.5 bg-white dark:bg-slate-900 border border-gray-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none shadow-sm text-gray-900 dark:text-white transition-colors" 
            placeholder="Ej. Área en especifica"
            name="Input.Description"
            id="Input_Description"
            x-model="form.description"></textarea>
    </div>
    
</form>