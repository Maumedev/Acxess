                        </div>
                    </div>
                </div> *@
            </div>

            <div class="mt-auto bg-blue-50 dark:bg-blue-900/20 p-4 rounded-lg border border-blue-100 dark:border-blue-900/50">
                <div class="flex justify-between text-sm">
                    <span class="text-blue-800 dark:text-blue-300">Vigencia: <strong class="text-blue-900 dark:text-blue-200">30 días</strong></span>
                    <span class="text-blue-800 dark:text-blue-300">Vence: <strong class="text-blue-900 dark:text-blue-200">08 Feb 2026</strong></span>
                </div>
            </div>
        </section>


        <section class="col-span-3 bg-slate-900 dark:bg-slate-950 text-white p-6 flex flex-col justify-between shadow-xl z-20 border-l border-slate-700 dark:border-slate-800">
            
            <div class="flex flex-col h-full">
                <div class="mb-6">
                    <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">
                        Método de Pago
                    </label>
                    <div class="flex bg-slate-800 p-1 rounded-lg">
                        <button @@click="paymentMethod = 'cash'" 
                                :class="paymentMethod === 'cash' ? 'bg-blue-600 text-white shadow' : 'text-gray-400 hover:text-white'"
                                class="flex-1 py-1.5 rounded-md text-xs font-bold transition-all text-center">
                            EFECTIVO
                        </button>
                        <button @@click="paymentMethod = 'transfer'" 
                                :class="paymentMethod === 'transfer' ? 'bg-blue-600 text-white shadow' : 'text-gray-400 hover:text-white'"
                                class="flex-1 py-1.5 rounded-md text-xs font-bold transition-all text-center">
                            TRANSFERENCIA
                        </button>
                    </div>
                </div>
                
                <div class="space-y-3 text-sm border-b border-gray-700 pb-4 mb-4 flex-1">
                    <div class="flex justify-between items-center">
                        <span class="text-gray-300" x-text="selectedPlan.name"></span>
                        <span class="font-mono" x-text="formatMoney(selectedPlan.price)"></span>
                    </div>
                    
                    <div class="flex justify-between text-gray-400 text-xs pl-2" x-show="locker" x-transition>
                        <span>+ Renta Locker</span>
                        <span class="font-mono">$50.00</span>
                    </div>
                    <div class="flex justify-between text-gray-400 text-xs pl-2" x-show="towel" x-transition>
                        <span>+ Toalla Limpia</span>
                        <span class="font-mono">$20.00</span>
                    </div>

                    <div class="flex justify-between text-green-400 bg-green-900/20 p-2 rounded border border-green-900/50 dashed-border" 
                         x-show="discountAmount > 0" x-transition>
                        <span class="flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                            <span x-text="getPromoName()"></span>
                        </span>
                        <span class="font-mono font-bold" x-text="'-' + formatMoney(discountAmount)"></span>
                    </div>
                </div>

                <div class="text-right mb-6">
                    <span class="block text-sm text-gray-400 mb-1">Total a Pagar</span>
                    <div class="text-5xl font-bold tracking-tight text-white transition-all" x-text="formatMoney(total)"></div>
                </div>

                <div class="mb-4">
                    <template x-if="paymentMethod === 'cash'">
                        <div>
                            <label class="block text-xs font-bold text-gray-400 mb-2">DINERO RECIBIDO</label>
                            <div class="relative group">
                                <span class="absolute left-3 top-3 text-gray-400 text-xl group-focus-within:text-green-500">$</span>
                                <input type="number" x-model="amountGiven" 
                                       class="w-full bg-slate-800 dark:bg-slate-900 border border-slate-600 dark:border-slate-700 rounded-lg p-3 pl-8 text-2xl text-white font-mono focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition-colors" 
                                       placeholder="0.00">
                            </div>
                        </div>
                    </template>

                    <template x-if="paymentMethod === 'transfer'">
                        <div>
                            <label class="block text-xs font-bold text-gray-400 mb-2">REFERENCIA / FOLIO</label>
                            <div class="relative group">
                                <input type="text" x-model="transferRef" 
                                       class="w-full bg-slate-800 dark:bg-slate-900 border border-slate-600 dark:border-slate-700 rounded-lg p-3 text-lg text-white font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors uppercase" 
                                       placeholder="Ej. 45879">
                            </div>
                            <p class="text-[10px] text-gray-500 mt-2 text-right">Adjuntar comprobante opcional después del cobro.</p>
                        </div>
                    </template>
                </div>

                <div class="bg-slate-800 dark:bg-slate-900 rounded-lg p-4 border border-slate-700 dark:border-slate-800 transition-all" 
                     x-show="paymentMethod === 'cash'"
                     :class="amountGiven > 0 ? 'opacity-100' : 'opacity-50'">
                    <span class="block text-xs text-gray-400 uppercase text-center mb-1">Cambio a devolver</span>
                    <div class="text-3xl font-bold text-center font-mono" 
                         :class="change < 0 ? 'text-red-400' : 'text-green-400'"
                         x-text="change >= 0 ? formatMoney(change) : 'Falta dinero'">
                        $0.00
                    </div>
                </div>

                <button class="w-full bg-blue-600 hover:bg-blue-500 dark:bg-blue-700 dark:hover:bg-blue-600 text-white font-semibold py-4 px-6 rounded-lg shadow-lg transform active:scale-95 transition-all mt-4 flex justify-center items-center gap-2">
                    <span>COBRAR</span>
                </button>
            </div>
            
        </section>

    </div>
</div>

<script>
    document.addEventListener('alpine:init', () => {
        Alpine.data('posSystem', () => ({
            searchQuery: '',
            customer: { name: '', phone: '', email: '' },
            
            // Datos de Planes (Simulado)
            plans: [
                { id: 1, name: 'Mensualidad', desc: 'Acceso total 30 días', price: 500, capacity: 1 },
                { id: 2, name: 'Semanal', desc: 'Acceso 7 días', price: 150, capacity: 1 },
                { id: 3, name: 'Visita', desc: '1 día', price: 50, capacity: 1 },
                { id: 4, name: 'Pareja Mensual', desc: '30 días para 2 personas', price: 900, capacity: 2 },
            ],
            
            selectedPlan: {}, // Se llena en init
            locker: false,
            towel: false,
            
            // Promociones
            selectedPromoId: '',
            promos: {
                'promo1': { name: 'Desc. Estudiante', type: 'percent', value: 0.10 },
                'promo2': { name: 'Renov. Anticipada', type: 'fixed', value: 50 },
                'promo3': { name: '2x1 Parejas', type: 'fixed', value: 450 }, // Ejemplo
            },

            // Pago
            paymentMethod: 'cash', // 'cash' | 'transfer'
            amountGiven: '',
            transferRef: '',

            initSystem() {
                this.selectedPlan = this.plans[0];
                this.$nextTick(() => this.$refs.searchInput.focus());
            },

            get availablePlans() {
                return this.plans; // Aquí podrías filtrar si fuera necesario
            },

            selectPlan(plan) {
                this.selectedPlan = plan;
                // Resetear promo si cambia el plan por si no aplica
                if (this.selectedPromoId === 'promo3' && plan.id !== 4) {
                    this.selectedPromoId = '';
                }
            },

            selectUser(name) {
                this.searchQuery = '';
                this.customer.name = name;
                this.customer.phone = '55 1234 5678';
                // Lógica real de selección
            },

            get discountAmount() {
                if (!this.selectedPromoId) return 0;
                
                const promo = this.promos[this.selectedPromoId];
                if (!promo) return 0;

                if (promo.type === 'percent') {
                    return this.selectedPlan.price * promo.value;
                } else {
                    return promo.value;
                }
            },

            getPromoName() {
                return this.promos[this.selectedPromoId]?.name || 'Descuento';
            },

            get total() {
                let subtotal = this.selectedPlan.price;
                if (this.locker) subtotal += 50;
                if (this.towel) subtotal += 20;
                
                return Math.max(0, subtotal - this.discountAmount);
            },

            get change() {
                const given = parseFloat(this.amountGiven) || 0;
                return given - this.total;
            },

            formatMoney(amount) {
                return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(amount);
            }
        }));
    });
</script>
