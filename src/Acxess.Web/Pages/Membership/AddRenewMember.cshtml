                    1. Identificar Cliente <span class="bg-slate-200 dark:bg-slate-700 text-slate-600 dark:text-slate-300 px-1.5 rounded text-[10px] ml-2 font-mono">F1</span>
                </label>
                <div class="relative group">
                    <input x-ref="searchInput" type="text" x-model="searchQuery" placeholder="Nombre, ID o teléfono..." 
                           class="w-full p-3 bg-gray-50 dark:bg-slate-900 border border-gray-300 dark:border-slate-600 rounded-lg shadow-sm 
                                  focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:focus:border-blue-500 outline-none text-sm
                                  text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 transition-all">
                    <div class="absolute right-3 top-3.5 text-gray-400 group-focus-within:text-blue-500">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                    </div>
                </div>
                
                <div x-show="searchQuery.length > 0" x-transition class="mt-2 bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-600 rounded-md shadow-lg overflow-hidden">
                    <div @@click="selectUser('Juan Pérez')" class="p-3 hover:bg-gray-50 dark:hover:bg-slate-800 cursor-pointer border-b border-gray-100 dark:border-slate-700 flex justify-between group">
                        <div>
                            <p class="font-bold text-gray-800 dark:text-gray-200 group-hover:text-blue-600 dark:group-hover:text-blue-400">Juan Pérez</p>
                            <p class="text-xs text-gray-500">ID: 1024 • Vencido</p>
                        </div>
                        <span class="text-red-600 dark:text-red-400 font-bold text-xs bg-red-100 dark:bg-red-900/30 px-2 py-1 rounded h-fit">Vencido</span>
                    </div>
                </div>
            </div>

            <div class="flex items-center gap-2 my-2">
                <div class="h-px bg-gray-200 dark:bg-slate-600 flex-1"></div>
                <span class="text-gray-400 dark:text-gray-500 text-xs font-semibold">DATOS DEL TITULAR</span>
                <div class="h-px bg-gray-200 dark:bg-slate-600 flex-1"></div>
            </div>

            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Nombre Completo</label>
                    <input type="text" x-model="customer.name" class="mt-1 block w-full p-2 bg-gray-50 dark:bg-slate-900 border border-gray-300 dark:border-slate-600 rounded-md focus:ring-blue-500 text-gray-900 dark:text-white">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Teléfono</label>
                        <input type="tel" x-model="customer.phone" class="mt-1 block w-full p-2 bg-gray-50 dark:bg-slate-900 border border-gray-300 dark:border-slate-600 rounded-md focus:ring-blue-500 text-gray-900 dark:text-white">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Email</label>
                        <input type="email" x-model="customer.email" class="mt-1 block w-full p-2 bg-gray-50 dark:bg-slate-900 border border-gray-300 dark:border-slate-600 rounded-md focus:ring-blue-500 text-gray-900 dark:text-white">
                    </div>
                </div>
            </div>
        </section>


        <section class="col-span-6 bg-gray-50 dark:bg-[#0f1523] border-r border-gray-200 dark:border-slate-700 p-6 flex flex-col gap-6 overflow-y-auto custom-scrollbar relative">
            
            <div>
                <label class="block text-xs font-bold text-gray-500 dark:text-gray-400 uppercase mb-3">
                    2. Seleccionar Plan <span class="bg-slate-200 dark:bg-slate-700 text-slate-600 dark:text-slate-300 px-1.5 rounded text-[10px] ml-2 font-mono">F2</span>
