                            </div>
                        </div>

                        <div class="flex gap-2">
                            <input x-ref="couponInput" type="text" placeholder="CÓDIGO" class="w-full p-2 text-xs uppercase bg-white dark:bg-slate-900 border border-gray-300 dark:border-slate-700 rounded-lg focus:ring-green-500 outline-none">
