                                        <span x-text="plan.capacity + ' Personas'"></span>
                                    </span>
                                </div>
                                <span class="text-lg font-bold text-blue-600 dark:text-blue-400" x-text="'$' + plan.price"></span>
                            </div>

                            <div x-show="selectedPlan.id === plan.id" class="absolute top-2 right-2 text-blue-500" x-transition.scale>
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            </div>
                        </div>
                    </template>
                </div>
            </div>

            <div x-show="selectedPlan.capacity > 1" x-collapse>
                <div class="bg-purple-50 dark:bg-purple-900/10 border border-purple-100 dark:border-purple-900/30 rounded-lg p-4">
                    <h4 class="text-sm font-bold text-purple-800 dark:text-purple-300 mb-2 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                        Registro de Beneficiarios Adicionales
                    </h4>
                    <div class="space-y-3">
                        <template x-for="i in (selectedPlan.capacity - 1)">
                            <div class="flex gap-2">
                                <div class="relative w-full">
                                    <span class="absolute left-3 top-2.5 text-gray-400 text-xs font-bold" x-text="'#' + (i+1)"></span>
                                    <input type="text" :placeholder="'Nombre del beneficiario ' + (i+1)" 
                                           class="w-full pl-8 p-2 text-sm bg-white dark:bg-slate-900 border border-gray-300 dark:border-slate-600 rounded-md focus:ring-purple-500 outline-none">
                                </div>
                            </div>
                        </template>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-6 mt-2">
                
                <div>
                    <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">Complementos</h4>
                    <div class="space-y-2">
                        <label class="flex items-center justify-between p-2.5 bg-white dark:bg-slate-800 border dark:border-slate-700 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-slate-700 transition">
                            <div class="flex items-center gap-2">
                                <input type="checkbox" x-model="locker" class="w-4 h-4 text-blue-600 rounded focus:ring-blue-500 bg-gray-100 dark:bg-slate-900 border-gray-300 dark:border-slate-500">
                                <span class="text-sm text-gray-700 dark:text-gray-200">Renta Locker</span>
                            </div>
                            <span class="text-xs font-bold text-gray-500">+$50</span>
                        </label>
                        <label class="flex items-center justify-between p-2.5 bg-white dark:bg-slate-800 border dark:border-slate-700 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-slate-700 transition">
                            <div class="flex items-center gap-2">
                                <input type="checkbox" x-model="towel" class="w-4 h-4 text-blue-600 rounded focus:ring-blue-500 bg-gray-100 dark:bg-slate-900 border-gray-300 dark:border-slate-500">
                                <span class="text-sm text-gray-700 dark:text-gray-200">Toalla</span>
                            </div>
                            <span class="text-xs font-bold text-gray-500">+$20</span>
                        </label>
                    </div>
                </div>

                @* <div>
                    <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3 flex justify-between">
                        <span>Promociones</span>
                        <span class="text-[10px] text-blue-500 cursor-pointer hover:underline" @@click="$refs.couponInput.focus()">Tengo Cupón</span>
                    </h4>
                    
                    <div class="space-y-2">
                        <div class="relative">
                            <select x-model="selectedPromoId" class="w-full p-2.5 text-sm bg-white dark:bg-slate-800 border border-gray-300 dark:border-slate-700 rounded-lg appearance-none focus:ring-green-500 outline-none text-gray-700 dark:text-gray-300">
                                <option value="">-- Sin promoción --</option>
                                <option value="promo1">Descuento Estudiante (10%)</option>
                                <option value="promo2">Renovación Anticipada ($50 off)</option>
                                <option value="promo3" x-show="selectedPlan.id === 4">Promo Parejas (2x1 Inscripción)</option>
                            </select>
