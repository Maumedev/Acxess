@{
    ViewData["Title"] = "Mostrador";
}
<div class="h-full w-full flex flex-col bg-gray-100 dark:bg-[#0b0f19] transition-colors duration-300" 
     x-data="posSystem()"
     x-init="initSystem()">

    <div class="flex-1 grid grid-cols-12 gap-0 overflow-hidden">

        <section class="col-span-3 bg-white dark:bg-slate-800 border-r border-gray-200 dark:border-slate-700 p-6 flex flex-col gap-6 overflow-y-auto custom-scrollbar z-10">
            
